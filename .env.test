# .env.test

# Network Engine Configuration
PORT=5002
NODE_ENV=test

# Database Persistence Connection Variables
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres1234
DB_NAME=citizen_portal_test

# Cryptographic Token Signing Secrets
# JWT_ACCESS_SECRET: Validates full-privilege sessions for fully authorized users across protected API boundaries.
JWT_ACCESS_SECRET=test_mfa_secret_volatile_token_999

# JWT_MFA_SECRET: Signs short-lived, low-privilege tokens during Phase 1 login. 
# This token only allows access to the MFA verification endpoint and is strictly blocked from the rest of the app.
JWT_MFA_SECRET=test_mfa_secret_volatile_token_999